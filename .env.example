# ============================================================
# FabBot – Umgebungsvariablen
# Kopiere diese Datei: cp .env.example .env
# ============================================================

# ── Pflichtfelder ────────────────────────────────────────────

# Anthropic API Key (claude.ai → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram Bot Token (via @BotFather auf Telegram)
TELEGRAM_BOT_TOKEN=...

# Deine Telegram User-ID (via @userinfobot auf Telegram)
# Mehrere IDs mit Komma trennen: 123456789,987654321
TELEGRAM_ALLOWED_USER_IDS=123456789

# ── Optionale Felder (Web-Suche) ─────────────────────────────

# Tavily API Key – https://tavily.com
TAVILY_API_KEY=tvly-...

# Brave Search API Key – https://brave.com/search/api/
BRAVE_API_KEY=BSA...

# ── Optionale Felder (TTS) ───────────────────────────────────

# OpenAI API Key – https://platform.openai.com
# Primärer TTS-Provider – günstiger und einfacher als ElevenLabs
# Ohne Key: automatischer Fallback auf edge-tts
OPENAI_API_KEY=sk-...

# OpenAI TTS Stimme (default: nova)
# Optionen: alloy | echo | fable | onyx | nova | shimmer
# OPENAI_TTS_VOICE=nova

# OpenAI TTS Modell (default: tts-1)
# tts-1: günstiger (~$15/1M Zeichen)
# tts-1-hd: bessere Qualität (~$30/1M Zeichen)
# OPENAI_TTS_MODEL=tts-1

# TTS aktivieren/deaktivieren (default: true)
# TTS_ENABLED=true

# ── Optionale Felder (Sonstiges) ─────────────────────────────

# Optionale externe Pfade fuer file_agent (colon-separated)
# FABBOT_EXTRA_PATHS=/Volumes/MyDrive/foo:/Volumes/MyDrive/bar

# Context Window fuer chat_agent (default: 40)
# CHAT_CONTEXT_WINDOW=40

# Party Report – jeden Mittwoch 20:00 Uhr
# PARTY_REPORT_TIME=20:00
# PARTY_REPORT_DAY=2
