# ============================================================
# FabBot – Umgebungsvariablen
# Kopiere diese Datei: cp .env.example .env
# ============================================================

# ── Pflichtfelder ────────────────────────────────────────────

# Anthropic API Key (claude.ai → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram Bot Token (via @BotFather auf Telegram)
TELEGRAM_BOT_TOKEN=...

# Deine Telegram User-ID (via @userinfobot auf Telegram)
# Mehrere IDs mit Komma trennen: 123456789,987654321
TELEGRAM_ALLOWED_USER_IDS=123456789

# ── Optionale Felder (Web-Suche) ─────────────────────────────

# Tavily API Key – https://tavily.com
# Wird für erweiterte Web-Suche verwendet (empfohlen)
TAVILY_API_KEY=tvly-...

# Brave Search API Key – https://brave.com/search/api/
# Wird als Fallback für Web-Suche verwendet
BRAVE_API_KEY=BSA...

# Optionale externe Pfade fuer file_agent (colon-separated)
# FABBOT_EXTRA_PATHS=/Volumes/MyDrive/foo:/Volumes/MyDrive/bar
