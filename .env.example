# FabBot – Umgebungsvariablen
# Kopiere diese Datei nach .env und fülle die Werte ein.
# Pflichtfelder: TELEGRAM_BOT_TOKEN, TELEGRAM_ALLOWED_USER_IDS, ANTHROPIC_API_KEY

# ── Pflicht ──────────────────────────────────────────────────────────────────

# Telegram Bot Token (von @BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Deine Telegram User-ID(s) – Whitelist (kommagetrennt)
# Abfragen via @userinfobot oder `getUpdates`
TELEGRAM_ALLOWED_USER_IDS=123456789

# Anthropic API Key – https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Scheduler & Briefing ───────────────────────────────────────────

# Deine Telegram Chat-ID für tägliche Briefings, Scheduler und Watchdog-Alerts.
# In Direktchats meist identisch mit deiner User-ID, in Gruppen abweichend.
# Ohne diese Variable: Fallback auf erste ID in TELEGRAM_ALLOWED_USER_IDS.
# TELEGRAM_CHAT_ID=123456789

# Uhrzeit des Morning Briefings (HH:MM, 24h, Lokalzeit)
# BRIEFING_TIME=07:30

# Uhrzeit des täglichen Health Checks
# HEALTH_CHECK_TIME=06:00

# Uhrzeit der täglichen Session-Zusammenfassung
# SESSION_SUMMARY_TIME=23:30

# Wochentag und Uhrzeit des Party Reports (0=Mo … 6=So)
# PARTY_REPORT_DAY=2
# PARTY_REPORT_TIME=20:00

# ── Optional: LLM-Modelle ─────────────────────────────────────────────────────

# Konfigurierbare Anthropic-Modelle (Standardwerte sind bereits gesetzt)
# ANTHROPIC_MODEL_SONNET=claude-sonnet-4-20250514
# ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001

# ── Optional: Web-Suche ───────────────────────────────────────────────────────

# Tavily API Key – https://tavily.com (empfohlen)
# TAVILY_API_KEY=tvly-...

# Brave Search API Key – https://brave.com/search/api/ (Fallback)
# BRAVE_API_KEY=BSA...

# ── Optional: Retrieval / Second Brain ───────────────────────────────────────

# OpenAI API Key – für Embeddings (text-embedding-3-small) und TTS
# Ohne Key: Retrieval deaktiviert, /reindex schlägt fehl, TTS fällt auf edge-tts zurück
# OPENAI_API_KEY=sk-...

# OpenAI TTS Stimme und Modell
# OPENAI_TTS_VOICE=nova
# OPENAI_TTS_MODEL=tts-1

# ── Optional: Observability / LangSmith ──────────────────────────────────────

# LangSmith Tracing – https://smith.langchain.com
# Alle vier Variablen müssen gesetzt sein, damit Tracing aktiv wird.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT=FabBot
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Optional: WhatsApp ────────────────────────────────────────────────────────

# Port des whatsapp-web.js Microservice (Default: 8767)
# WA_SERVICE_PORT=8767

# ── Optional: TTS ─────────────────────────────────────────────────────────────

# TTS standardmäßig aktiviert (true/false)
# TTS_ENABLED=true

# ── Optional: Chat-Kontext ────────────────────────────────────────────────────

# Anzahl der Nachrichten im Chat-Kontext (Default: 40, Min: 10, Max: 200)
# CHAT_CONTEXT_WINDOW=40

# Minimale Human-Messages für Session-Zusammenfassung (Default: 10)
# SESSION_SUMMARY_MIN_MESSAGES=10

# ── Optional: Datei-Zugriff ───────────────────────────────────────────────────

# Zusätzliche Pfade für den File-Agent (Doppelpunkt-getrennt)
# FABBOT_EXTRA_PATHS=/Volumes/McAir SSD/fmorena/PythonProject
